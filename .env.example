# Supabase (https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App — production: set to your Vercel domain (e.g. https://slotify.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth (Faza 2): u Supabase Dashboard → Authentication → Providers → Email
# isključi "Confirm email" — projekat nema produkcijski domen za verifikaciju.

# Email (Faza 5+)
# Production: verify domain in Resend and set RESEND_FROM_EMAIL to your domain
RESEND_API_KEY=
RESEND_FROM_EMAIL=Slotify <onboarding@resend.dev>

# Cron (Faza 7+)
# Production: generate a strong random secret; Vercel Cron sends Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
